{
  "name": "favorites",
  "version": "0.1.0",
  "description": "A place to mirror favorite essays",
  "homepage": "https://github.com/theodore-s-beers/favorites#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theodore-s-beers/favorites.git"
  },
  "license": "MIT",
  "author": "Theo Beers",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "lint": "eslint --fix . && stylelint --fix styles.css",
    "minify-html": "fd -e html ^index -x html-minifier-next --config-file html-minifier.json {} -o {}",
    "prettify-all": "prettier --write .",
    "prettify-html": "prettier --write '**/index.html'",
    "sort-manifest": "sort-package-json",
    "test": "echo 'Error: no test specified' && exit 1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "html-minifier-next": "^6.2.7",
    "prettier": "^3.8.3",
    "sort-package-json": "^3.6.1",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
